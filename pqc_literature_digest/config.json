      "protocol": ["protocol", "key exchange", "authentication", "AKE", "TLS", "MPC", "secure computation"],
      "implementation": ["implementation", "constant-time", "software", "hardware", "FPGA", "AVX", "ARM", "side-channel", "masking"],
      "theory": ["proof", "security reduction", "assumption", "lower bound", "indistinguishability", "random oracle", "QROM"],
      "NTT": ["NTT", "number theoretic transform"],
      "polynomial multiplication": ["polynomial multiplication", "polynomial multiplier", "negacyclic", "Toom-Cook", "Karatsuba"],
      "PQC": ["post-quantum", "post quantum", "PQC", "lattice", "LWE", "SIS", "code-based", "isogeny", "hash-based", "Kyber", "Dilithium", "Falcon", "SPHINCS", "ML-KEM", "ML-DSA"]
