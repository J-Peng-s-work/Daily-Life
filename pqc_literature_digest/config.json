        "https://eprint.iacr.org/rss",
        "https://eprint.iacr.org/"
      ]
    },
    "dblp": {
      "enabled": true,
      "priority": 3,
      "queries": [
        "post quantum cryptography",
        "lattice cryptography",
        "PQC NTT",
        "polynomial multiplication cryptography"
      ]
    },
    "crossref": {
      "enabled": true,
      "priority": 2,
      "queries": [
        "post-quantum cryptography",
        "lattice-based cryptography",
        "polynomial multiplication NTT cryptography"
      ],
      "mailto": "126105287@umail.ucc.ie"  
    },
    "arxiv": {
      "enabled": true,
      "priority": 2,
      "queries": [
        "all:\"post-quantum cryptography\" OR all:\"lattice cryptography\"",
        "all:\"number theoretic transform\" AND all:cryptography",
